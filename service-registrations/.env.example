NODE_ENV=development

PORT=3002

MONGO_URI=<MONGODB_CONNECTION_STRING>

# URL base de Service Events (Servicio A). Ajusta el puerto al que realmente
# use service-events en tu entorno (su .env.example por defecto usa PORT=3000).
EVENTS_SERVICE_URL=http://localhost:3000

# Debe ser exactamente el mismo secreto firmado por service-auth (JWT_SECRET_KEY).
JWT_SECRET=<CHANGE_ME>

# Deben coincidir con JwtSettings:Issuer / JwtSettings:Audience de service-auth.
JWT_ISSUER=sistema-eventos-auth
JWT_AUDIENCE=sistema-eventos-services
JWT_ALGORITHM=HS256

CORS_ORIGIN=http://localhost:5173
