{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-auth-service-events",
    "name": "AuthService — Sistema Eventos",
    "description": "Colección para el microservicio de autenticación del monorepo Sistema-Eventos.\n\n**Base URL:** `{{baseUrl}}` (default `http://localhost:5001`)\n\n**Flujo:** Health → Login Admin / Register → Profile (Bearer automático).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001" },
    { "key": "accessToken", "value": "" },
    { "key": "testEmail", "value": "usuario.test@example.com" },
    { "key": "testPassword", "value": "Str0ng!Pass1" },
    { "key": "adminEmail", "value": "admin@eventos.local" },
    { "key": "adminPassword", "value": "Admin1234!" },
    { "key": "resetToken", "value": "" },
    { "key": "verifyToken", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth — públicos",
      "item": [
        {
          "name": "POST Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.accessToken) pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  if (body.data && body.data.user && body.data.user.email) pm.collectionVariables.set('testEmail', body.data.user.email);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Demo\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register",
            "description": "Registro con rol **User**."
          }
        },
        {
          "name": "POST Login (usuario)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.accessToken) pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "POST Login (admin seed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.accessToken) pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "Admin seed: `admin@eventos.local` / `Admin1234!` — rol **Admin**."
          }
        },
        {
          "name": "POST Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/forgot-password"
          }
        },
        {
          "name": "POST Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"N3w!Str0ngPass\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/reset-password"
          }
        },
        {
          "name": "POST Verify Email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{verifyToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/verify-email"
          }
        },
        {
          "name": "POST Resend Verification",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/resend-verification"
          }
        }
      ]
    },
    {
      "name": "Auth — con JWT",
      "item": [
        {
          "name": "GET Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/profile"
          }
        },
        {
          "name": "PUT Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Actualizado\",\n  \"profileImageUrl\": \"https://res.cloudinary.com/demo/image/upload/sample.jpg\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/profile"
          }
        },
        {
          "name": "POST Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{testPassword}}\",\n  \"newPassword\": \"N3w!Str0ngPass\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/change-password"
          }
        }
      ]
    },
    {
      "name": "Casos de error",
      "item": [
        {
          "name": "Login credenciales inválidas",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noexiste@example.com\",\n  \"password\": \"WrongPass1!\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Register password débil",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Weak\",\n  \"email\": \"weak@example.com\",\n  \"password\": \"123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Profile sin token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/profile"
          }
        }
      ]
    }
  ]
}
